        "Нэр": r.employee,
        "Албан тушаал": r.position,
        "Хэрэглэл": r.item,
        "Размер": r.size,
        "Тоо": r.qty,
        "Олгосон огноо": r.issued_date,
        "Тэмдэглэл": r.note,
