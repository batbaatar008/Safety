  const [login, setLogin] = useState({ username: "", password: "" });
  const [activeTab, setActiveTab] = useState("records");

  const [users, setUsers] = useState(hasConfig ? [] : [DEFAULT_ADMIN]);
  const [records, setRecords] = useState([]);

  const [userForm, setUserForm] = useState({
    full_name: "",
    username: "",
    password: "",
    role: "viewer",
  });

  const [recordForm, setRecordForm] = useState({
    employee: employees[0].name,
    position: employees[0].position,
    item: uniforms[0],
    size: "",
    qty: 1,
    issued_date: new Date().toISOString().slice(0, 10),
    note: "",
  });

  const [search, setSearch] = useState("");
  const [employeeFilter, setEmployeeFilter] = useState("all");
  const [uniformFilter, setUniformFilter] = useState("all");

  const canManageUsers = currentUser?.role === "admin";
  const canEditRecords = currentUser?.role === "admin" || currentUser?.role === "manager";

  useEffect(() => {
    let mounted = true;
    async function init() {
      if (!supabase) {
        if (mounted) setReady(true);
        return;
      }
      await ensureDefaultAdmin();
      if (!mounted) return;
      await Promise.all([loadUsers(), loadRecords()]);
      if (mounted) setReady(true);
    }
    init();
    return () => {
      mounted = false;
    };
  }, []);

  async function ensureDefaultAdmin() {
    if (!supabase) return;
    const { data, error } = await supabase.from(TABLE_USERS).select("id, username").eq("username", DEFAULT_ADMIN.username).maybeSingle();
    if (error) {
      setStatus(`Админ шалгахад алдаа: ${error.message}`);
      return;
    }
    if (!data) {
      const { error: insertError } = await supabase.from(TABLE_USERS).insert([DEFAULT_ADMIN]);
      if (insertError) setStatus(`Анхны админ үүсгэхэд алдаа: ${insertError.message}`);
    }
  }

  async function loadUsers() {
    if (!supabase) return;
    const { data, error } = await supabase.from(TABLE_USERS).select("*").order("created_at", { ascending: false });
    if (error) {
      setStatus(`Хэрэглэгч ачаалахад алдаа: ${error.message}`);
      return;
    }
    setUsers(data || []);
  }

  async function loadRecords() {
    if (!supabase) return;
    const { data, error } = await supabase.from(TABLE_RECORDS).select("*").order("issued_date", { ascending: false }).order("created_at", { ascending: false });
    if (error) {
      setStatus(`Бүртгэл ачаалахад алдаа: ${error.message}`);
      return;
    }
    setRecords(data || []);
  }

  async function handleLogin() {
    if (!login.username || !login.password) {
      alert("Нэвтрэх нэр, нууц үгээ оруулна уу.");
      return;
    }

    if (!supabase) {
      if (login.username === DEFAULT_ADMIN.username && login.password === DEFAULT_ADMIN.password) {
        setCurrentUser(DEFAULT_ADMIN);
        setStatus("Demo admin амжилттай нэвтэрлээ.");
      } else {
        alert("Demo горимд зөвхөн admin / 1234 ашиглана.");
      }
      return;
    }

    const { data, error } = await supabase
      .from(TABLE_USERS)
      .select("*")
      .eq("username", login.username)
      .eq("password", login.password)
      .eq("is_active", true)
      .maybeSingle();

    if (error) {
      alert(`Нэвтрэх үед алдаа: ${error.message}`);
      return;
    }
    if (!data) {
      alert("Нэвтрэх нэр эсвэл нууц үг буруу байна.");
      return;
    }

    setCurrentUser(data);
    setStatus(`${data.full_name} амжилттай нэвтэрлээ.`);
  }

  function logout() {
    setCurrentUser(null);
    setLogin({ username: "", password: "" });
  }

  async function addUser() {
    if (!canManageUsers) return;
    if (!userForm.full_name || !userForm.username || !userForm.password) {
      alert("Хэрэглэгчийн мэдээллийг бүрэн оруулна уу.");
      return;
    }
    if (!supabase) {
      alert("Demo горимд онлайн хэрэглэгч үүсгэхгүй.");
      return;
    }
    const payload = { ...userForm, is_active: true };
    const { error } = await supabase.from(TABLE_USERS).insert([payload]);
    if (error) {
      alert(`Хэрэглэгч нэмэхэд алдаа: ${error.message}`);
      return;
    }
    setUserForm({ full_name: "", username: "", password: "", role: "viewer" });
    await loadUsers();
    setStatus("Шинэ хэрэглэгч үүсгэлээ.");
  }

  async function toggleUserActive(user) {
    if (!canManageUsers || !supabase) return;
    const { error } = await supabase.from(TABLE_USERS).update({ is_active: !user.is_active }).eq("id", user.id);
    if (error) {
      alert(`Хэрэглэгчийн төлөв өөрчлөхөд алдаа: ${error.message}`);
      return;
    }
    await loadUsers();
  }

  async function addRecord() {
    if (!canEditRecords) return;
    if (!recordForm.employee || !recordForm.item || !recordForm.issued_date) {
      alert("Бүртгэлийн мэдээллээ бүрэн оруулна уу.");
      return;
    }
    if (!supabase) {
      const localRecord = {
        id: `local-${Date.now()}`,
        department: DEPARTMENT,
        employee: recordForm.employee,
        position: recordForm.position,
        item: recordForm.item,
        size: recordForm.size,
        qty: Number(recordForm.qty || 1),
        issued_date: recordForm.issued_date,
        note: recordForm.note,
        created_by: currentUser?.username || "admin",
      };
      setRecords((prev) => [localRecord, ...prev]);
      setStatus("Demo горимд локал бүртгэл нэмэгдлээ.");
      return;
    }

    const payload = {
      department: DEPARTMENT,
      employee: recordForm.employee,
      position: recordForm.position,
      item: recordForm.item,
      size: recordForm.size,
      qty: Number(recordForm.qty || 1),
      issued_date: recordForm.issued_date,
      note: recordForm.note,
      created_by: currentUser?.username || "",
    };

    const { error } = await supabase.from(TABLE_RECORDS).insert([payload]);
    if (error) {
      alert(`Бүртгэл хадгалахад алдаа: ${error.message}`);
      return;
    }
    await loadRecords();
    setStatus("Бүртгэл амжилттай хадгалагдлаа.");
  }

  async function deleteRecord(id) {
    if (!canEditRecords) return;
    if (!window.confirm("Энэ бүртгэлийг устгах уу?")) return;

    if (!supabase) {
      setRecords((prev) => prev.filter((r) => r.id !== id));
      return;
    }

    const { error } = await supabase.from(TABLE_RECORDS).delete().eq("id", id);
    if (error) {
      alert(`Бүртгэл устгахад алдаа: ${error.message}`);
      return;
    }
    await loadRecords();
  }

  function handleEmployeeChange(name) {
    setRecordForm((prev) => ({ ...prev, employee: name, position: employeeMap[name] || "" }));
  }

  const filteredRecords = useMemo(() => {
    return records.filter((r) => {
      const q = search.trim().toLowerCase();
      const matchQ = !q || [r.employee, r.position, r.item, r.size, r.note, r.created_by].join(" ").toLowerCase().includes(q);
      const matchEmployee = employeeFilter === "all" || r.employee === employeeFilter;
      const matchUniform = uniformFilter === "all" || r.item === uniformFilter;
      return matchQ && matchEmployee && matchUniform;
    });
  }, [records, search, employeeFilter, uniformFilter]);

  const summary = useMemo(() => {
    const totalQty = filteredRecords.reduce((sum, r) => sum + Number(r.qty || 0), 0);
    const employeeCount = new Set(filteredRecords.map((r) => r.employee)).size;
    const grouped = filteredRecords.reduce((acc, r) => {
      acc[r.item] = (acc[r.item] || 0) + Number(r.qty || 0);
      return acc;
    }, {});
    const topItem = Object.entries(grouped).sort((a, b) => b[1] - a[1])[0]?.[0] || "—";
    return { totalQty, employeeCount, topItem };
  }, [filteredRecords]);

  function exportRecordsReport() {
    exportCSV(
      `bbth-burtgel-${new Date().toISOString().slice(0, 10)}.csv`,
      filteredRecords.map((r, i) => ({
        "№": i + 1,
        "Хэлтэс": r.department,
        "Нэр": r.employee,
        "Албан тушаал": r.position,
        "Хэрэглэл": r.item,
        "Размер": r.size,
        "Тоо": r.qty,
        "Огноо": r.issued_date,
        "Тэмдэглэл": r.note,
        "Бүртгэсэн": r.created_by,
      }))
    );
  }

  function exportSummaryReport() {
    const grouped = {};
    filteredRecords.forEach((r) => {
      const key = `${r.employee}|||${r.item}`;
      if (!grouped[key]) grouped[key] = { employee: r.employee, item: r.item, qty: 0 };
      grouped[key].qty += Number(r.qty || 0);
    });
    exportCSV(
      `bbth-tailan-${new Date().toISOString().slice(0, 10)}.csv`,
      Object.values(grouped).map((r, i) => ({
        "№": i + 1,
        "Нэр": r.employee,
        "Хэрэглэл": r.item,
        "Нийт": r.qty,
      }))
    );
  }

  if (!ready) {
    return <div style={{ minHeight: "100vh", display: "grid", placeItems: "center", fontFamily: "Arial, sans-serif" }}>Ачаалж байна...</div>;
  }

  if (!currentUser) {
    return (
      <div
        style={{
          minHeight: "100vh",
          fontFamily: "Arial, sans-serif",
          background:
            "radial-gradient(circle at top left, rgba(125,211,252,0.45), transparent 30%), radial-gradient(circle at top right, rgba(59,130,246,0.30), transparent 30%), linear-gradient(135deg,#0f172a 0%,#0b3b66 45%,#0ea5e9 100%)",
          display: "grid",
          placeItems: "center",
          padding: 20,
        }}
      >
        <div style={{ ...cardStyle, width: "100%", maxWidth: 480, padding: 28 }}>
          <div style={{ display: "flex", gap: 16, alignItems: "center" }}>
            <div
              style={{
                width: 72,
                height: 72,
                borderRadius: 24,
                background: "linear-gradient(135deg,#0f172a,#0ea5e9)",
                display: "grid",
                placeItems: "center",
                color: "white",
              }}
            >
              <Building2 size={34} />
            </div>
            <div>
              <div style={{ fontSize: 12, color: "#334155", fontWeight: 700 }}>{COMPANY}</div>
              <div style={{ fontSize: 24, fontWeight: 800, color: "#0f172a", lineHeight: 1.2 }}>{APP_TITLE}</div>
              <div style={{ fontSize: 13, color: "#475569", marginTop: 6 }}>{DEPARTMENT}</div>
            </div>
          </div>

          <div style={{ display: "grid", gap: 12, marginTop: 22 }}>
            <div>
              <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Нэвтрэх нэр</label>
              <input style={inputStyle} value={login.username} onChange={(e) => setLogin({ ...login, username: e.target.value })} />
            </div>
            <div>
              <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Нууц үг</label>
              <input type="password" style={inputStyle} value={login.password} onChange={(e) => setLogin({ ...login, password: e.target.value })} />
            </div>
            <button style={primaryBtn} onClick={handleLogin}>Нэвтрэх</button>
          </div>

          <div style={{ marginTop: 18, display: "grid", gap: 8, fontSize: 13, color: "#475569" }}>
            <div style={{ display: "flex", gap: 8, alignItems: "center" }}><ShieldCheck size={16} />Админ бусад хэрэглэгчид эрх нээнэ</div>
            <div style={{ display: "flex", gap: 8, alignItems: "center" }}><Users size={16} />Зөвхөн ББТХ-ийн 7 инженер бүртгэгдэнэ</div>
            <div style={{ display: "flex", gap: 8, alignItems: "center" }}><Shirt size={16} />7 ангиллын хувцас, хэрэглэлийн бүртгэлтэй</div>
          </div>

          <div style={{ marginTop: 16, fontSize: 12, color: "#475569" }}>Demo: <b>admin</b> / <b>1234</b></div>
        </div>
      </div>
    );
  }

  return (
    <div
      style={{
        minHeight: "100vh",
        fontFamily: "Arial, sans-serif",
        background:
          "radial-gradient(circle at top left, rgba(186,230,253,0.55), transparent 22%), radial-gradient(circle at right, rgba(125,211,252,0.35), transparent 24%), linear-gradient(180deg,#eff6ff 0%,#e0f2fe 40%,#f8fafc 100%)",
        padding: 20,
      }}
    >
      <div style={{ maxWidth: 1400, margin: "0 auto" }}>
        <div style={{ ...cardStyle, padding: 24, marginBottom: 18 }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", gap: 16, flexWrap: "wrap" }}>
            <div style={{ display: "flex", gap: 16, alignItems: "center" }}>
              <div
                style={{
                  width: 72,
                  height: 72,
                  borderRadius: 24,
                  background: "linear-gradient(135deg,#0f172a,#0ea5e9)",
                  display: "grid",
                  placeItems: "center",
                  color: "white",
                }}
