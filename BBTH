        </div>

        <div style={{ display: "flex", gap: 10, flexWrap: "wrap", marginBottom: 16 }}>
          <button style={activeTab === "records" ? primaryBtn : secondaryBtn} onClick={() => setActiveTab("records")}>Бүртгэл</button>
          {canManageUsers && <button style={activeTab === "users" ? primaryBtn : secondaryBtn} onClick={() => setActiveTab("users")}>Хэрэглэгчийн эрх</button>}
          <button style={activeTab === "setup" ? primaryBtn : secondaryBtn} onClick={() => setActiveTab("setup")}>Суулгах заавар</button>
        </div>

        {activeTab === "records" && (
          <div style={{ display: "grid", gridTemplateColumns: "380px 1fr", gap: 18 }}>
            <div style={{ ...cardStyle, padding: 20, alignSelf: "start" }}>
              <div style={{ fontSize: 20, fontWeight: 800, color: "#0f172a", marginBottom: 16 }}>Шинэ бүртгэл</div>
              <div style={{ display: "grid", gap: 12 }}>
                <div>
                  <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Ажилтан</label>
                  <select style={inputStyle} value={recordForm.employee} onChange={(e) => handleEmployeeChange(e.target.value)} disabled={!canEditRecords}>
                    {employees.map((e) => <option key={e.name} value={e.name}>{e.name}</option>)}
                  </select>
                </div>
                <div>
                  <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Албан тушаал</label>
                  <input style={{ ...inputStyle, background: "#f8fafc" }} value={recordForm.position} readOnly />
                </div>
                <div>
                  <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Хэрэглэлийн төрөл</label>
                  <select style={inputStyle} value={recordForm.item} onChange={(e) => setRecordForm({ ...recordForm, item: e.target.value })} disabled={!canEditRecords}>
                    {uniforms.map((u) => <option key={u} value={u}>{u}</option>)}
                  </select>
                </div>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
                  <div>
                    <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Размер</label>
                    <input style={inputStyle} value={recordForm.size} onChange={(e) => setRecordForm({ ...recordForm, size: e.target.value })} disabled={!canEditRecords} />
                  </div>
                  <div>
                    <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Тоо</label>
                    <input type="number" min="1" style={inputStyle} value={recordForm.qty} onChange={(e) => setRecordForm({ ...recordForm, qty: e.target.value })} disabled={!canEditRecords} />
                  </div>
                </div>
                <div>
                  <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Олгосон огноо</label>
                  <input type="date" style={inputStyle} value={recordForm.issued_date} onChange={(e) => setRecordForm({ ...recordForm, issued_date: e.target.value })} disabled={!canEditRecords} />
                </div>
                <div>
                  <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Тэмдэглэл</label>
                  <textarea style={{ ...inputStyle, minHeight: 90, resize: "vertical" }} value={recordForm.note} onChange={(e) => setRecordForm({ ...recordForm, note: e.target.value })} disabled={!canEditRecords} />
                </div>
                <button style={{ ...primaryBtn, opacity: canEditRecords ? 1 : 0.6 }} onClick={addRecord} disabled={!canEditRecords}><span style={{ display: "inline-flex", gap: 8, alignItems: "center" }}><Plus size={16} />Хадгалах</span></button>
              </div>
            </div>

            <div style={{ ...cardStyle, padding: 20 }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", gap: 10, flexWrap: "wrap", marginBottom: 16 }}>
                <div style={{ fontSize: 20, fontWeight: 800, color: "#0f172a" }}>Бүртгэлийн жагсаалт</div>
                <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
                  <button style={secondaryBtn} onClick={loadRecords}><span style={{ display: "inline-flex", gap: 8, alignItems: "center" }}><RefreshCw size={16} />Шинэчлэх</span></button>
                  <button style={secondaryBtn} onClick={exportRecordsReport}><span style={{ display: "inline-flex", gap: 8, alignItems: "center" }}><Download size={16} />Бүртгэл экспорт</span></button>
                  <button style={secondaryBtn} onClick={exportSummaryReport}><span style={{ display: "inline-flex", gap: 8, alignItems: "center" }}><Download size={16} />Тайлан экспорт</span></button>
                </div>
              </div>

              <div style={{ display: "grid", gridTemplateColumns: "1.2fr 1fr 1fr", gap: 12, marginBottom: 16 }}>
                <div style={{ position: "relative" }}>
                  <Search size={16} style={{ position: "absolute", left: 12, top: 13, color: "#64748b" }} />
                  <input style={{ ...inputStyle, paddingLeft: 36 }} placeholder="Хайлт..." value={search} onChange={(e) => setSearch(e.target.value)} />
                </div>
                <select style={inputStyle} value={employeeFilter} onChange={(e) => setEmployeeFilter(e.target.value)}>
                  <option value="all">Бүх ажилтан</option>
                  {employees.map((e) => <option key={e.name} value={e.name}>{e.name}</option>)}
                </select>
                <select style={inputStyle} value={uniformFilter} onChange={(e) => setUniformFilter(e.target.value)}>
                  <option value="all">Бүх төрөл</option>
                  {uniforms.map((u) => <option key={u} value={u}>{u}</option>)}
                </select>
              </div>

              <div style={{ overflow: "auto", border: "1px solid #dbeafe", borderRadius: 18, background: "white" }}>
                <table style={{ width: "100%", minWidth: 950, borderCollapse: "collapse" }}>
                  <thead>
                    <tr style={{ background: "#f8fafc", textAlign: "left" }}>
                      {["№", "Нэр", "Албан тушаал", "Хэрэглэл", "Размер", "Тоо", "Огноо", "Бүртгэсэн", "Тэмдэглэл", "Үйлдэл"].map((h) => (
                        <th key={h} style={{ padding: 12, borderBottom: "1px solid #e2e8f0", fontSize: 13, color: "#334155" }}>{h}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {filteredRecords.length ? filteredRecords.map((r, i) => (
                      <tr key={r.id || i}>
                        <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>{i + 1}</td>
                        <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9", fontWeight: 700 }}>{r.employee}</td>
                        <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>{r.position}</td>
                        <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>{r.item}</td>
                        <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>{r.size || "—"}</td>
                        <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>{r.qty}</td>
                        <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>{r.issued_date}</td>
                        <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>{r.created_by || "—"}</td>
                        <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>{r.note || "—"}</td>
                        <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>
                          <button style={{ ...secondaryBtn, padding: "8px 10px", opacity: canEditRecords ? 1 : 0.6 }} onClick={() => deleteRecord(r.id)} disabled={!canEditRecords}><span style={{ display: "inline-flex", gap: 6, alignItems: "center" }}><Trash2 size={14} />Устгах</span></button>
                        </td>
                      </tr>
                    )) : (
                      <tr>
                        <td colSpan={10} style={{ padding: 24, textAlign: "center", color: "#64748b" }}>Бүртгэл олдсонгүй.</td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        )}

        {activeTab === "users" && canManageUsers && (
          <div style={{ display: "grid", gridTemplateColumns: "360px 1fr", gap: 18 }}>
            <div style={{ ...cardStyle, padding: 20, alignSelf: "start" }}>
              <div style={{ fontSize: 20, fontWeight: 800, color: "#0f172a", marginBottom: 16 }}>Шинэ хэрэглэгч</div>
              <div style={{ display: "grid", gap: 12 }}>
                <div>
                  <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Овог нэр</label>
                  <input style={inputStyle} value={userForm.full_name} onChange={(e) => setUserForm({ ...userForm, full_name: e.target.value })} />
                </div>
                <div>
                  <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Нэвтрэх нэр</label>
                  <input style={inputStyle} value={userForm.username} onChange={(e) => setUserForm({ ...userForm, username: e.target.value })} />
                </div>
                <div>
                  <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Нууц үг</label>
                  <input style={inputStyle} value={userForm.password} onChange={(e) => setUserForm({ ...userForm, password: e.target.value })} />
                </div>
                <div>
                  <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Эрхийн түвшин</label>
                  <select style={inputStyle} value={userForm.role} onChange={(e) => setUserForm({ ...userForm, role: e.target.value })}>
                    <option value="admin">Админ</option>
                    <option value="manager">Хариуцагч</option>
                    <option value="viewer">Зөвхөн харах</option>
                  </select>
                </div>
                <button style={primaryBtn} onClick={addUser}><span style={{ display: "inline-flex", gap: 8, alignItems: "center" }}><UserCog size={16} />Хэрэглэгч үүсгэх</span></button>
              </div>
            </div>

            <div style={{ ...cardStyle, padding: 20 }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", gap: 10, flexWrap: "wrap", marginBottom: 16 }}>
                <div style={{ fontSize: 20, fontWeight: 800, color: "#0f172a" }}>Хэрэглэгчийн жагсаалт</div>
                <button style={secondaryBtn} onClick={loadUsers}><span style={{ display: "inline-flex", gap: 8, alignItems: "center" }}><RefreshCw size={16} />Шинэчлэх</span></button>
              </div>

              <div style={{ overflow: "auto", border: "1px solid #dbeafe", borderRadius: 18, background: "white" }}>
                <table style={{ width: "100%", minWidth: 760, borderCollapse: "collapse" }}>
                  <thead>
                    <tr style={{ background: "#f8fafc", textAlign: "left" }}>
                      {["№", "Овог нэр", "Нэвтрэх нэр", "Эрх", "Төлөв", "Үйлдэл"].map((h) => (
                        <th key={h} style={{ padding: 12, borderBottom: "1px solid #e2e8f0", fontSize: 13, color: "#334155" }}>{h}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {users.map((u, i) => {
                      const badge = getRoleBadge(u.role);
                      return (
                        <tr key={u.id || i}>
                          <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>{i + 1}</td>
                          <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9", fontWeight: 700 }}>{u.full_name}</td>
                          <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>{u.username}</td>
                          <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}><Badge color={badge.color} text={badge.text}>{badge.label}</Badge></td>
                          <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}><Badge color={u.is_active ? "#dcfce7" : "#fef3c7"} text={u.is_active ? "#166534" : "#92400e"}>{u.is_active ? "Идэвхтэй" : "Идэвхгүй"}</Badge></td>
                          <td style={{ padding: 12, borderBottom: "1px solid #f1f5f9" }}>
                            {u.username === DEFAULT_ADMIN.username ? (
                              <span style={{ color: "#64748b", fontSize: 13 }}>Үндсэн админ</span>
                            ) : (
                              <button style={{ ...secondaryBtn, padding: "8px 10px" }} onClick={() => toggleUserActive(u)}>{u.is_active ? "Идэвхгүй болгох" : "Идэвхжүүлэх"}</button>
                            )}
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        )}

        {activeTab === "setup" && (
          <div style={{ ...cardStyle, padding: 24 }}>
            <div style={{ fontSize: 22, fontWeight: 800, color: "#0f172a", marginBottom: 14 }}>Supabase SQL</div>
            <pre style={{ marginTop: 12, background: "#0f172a", color: "#e2e8f0", padding: 18, borderRadius: 18, overflow: "auto", fontSize: 12 }}>
{`create table if not exists public.app_users (
  id uuid primary key default gen_random_uuid(),
  full_name text not null,
  username text not null unique,
  password text not null,
  role text not null default 'viewer',
  is_active boolean not null default true,
  created_at timestamptz not null default now()
);

create table if not exists public.uniform_records (
  id uuid primary key default gen_random_uuid(),
  department text not null,
  employee text not null,
  position text not null,
  item text not null,
  size text,
  qty integer not null default 1,
  issued_date date not null,
  note text,
  created_by text,
  created_at timestamptz not null default now()
);

alter table public.app_users enable row level security;
alter table public.uniform_records enable row level security;

drop policy if exists "users read" on public.app_users;
drop policy if exists "users insert" on public.app_users;
drop policy if exists "users update" on public.app_users;
drop policy if exists "records read" on public.uniform_records;
drop policy if exists "records insert" on public.uniform_records;
drop policy if exists "records delete" on public.uniform_records;

create policy "users read" on public.app_users for select using (true);
create policy "users insert" on public.app_users for insert with check (true);
create policy "users update" on public.app_users for update using (true);

create policy "records read" on public.uniform_records for select using (true);
create policy "records insert" on public.uniform_records for insert with check (true);
create policy "records delete" on public.uniform_records for delete using (true);`}
            </pre>
            <div style={{ marginTop: 14, color: "#334155", lineHeight: 1.7 }}>
              <p>1. SUPABASE_URL, SUPABASE_ANON_KEY утгаа өөрийн төслөөр солино.</p>
              <p>2. Дээрх SQL-ийг ажиллуулна.</p>
              <p>3. Дараа нь Vercel дээр deploy хийгээд линкээ ашиглана.</p>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
