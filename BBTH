function csvEscape(v) {
  const s = String(v ?? "");
  if (s.includes(",") || s.includes('"') || s.includes("
")) return '"' + s.replace(/"/g, '""') + '"';
  return s;
}

function exportCSV(filename, rows) {
  if (!rows.length) {
    alert("Экспортлох өгөгдөл алга.");
    return;
  }
  const headers = Object.keys(rows[0]);
  const content = [headers.map(csvEscape).join(",")]
    .concat(rows.map((row) => headers.map((h) => csvEscape(row[h])).join(",")))
    .join("
");
  const blob = new Blob([content], { type: "text/csv;charset=utf-8;" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = filename;
  a.click();
  URL.revokeObjectURL(url);
}

function Badge({ children, tone = "default" }) {
  const styles = {
    default: { background: "#e2e8f0", color: "#0f172a" },
    green: { background: "#dcfce7", color: "#166534" },
    blue: { background: "#dbeafe", color: "#1d4ed8" },
    amber: { background: "#fef3c7", color: "#92400e" },
    red: { background: "#fee2e2", color: "#b91c1c" },
  };
  return <span style={{ ...styles[tone], padding: "6px 10px", borderRadius: 999, fontSize: 12, fontWeight: 700 }}>{children}</span>;
}

