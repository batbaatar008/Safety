                  <label style={{ display: "block", marginBottom: 6, fontWeight: 700, fontSize: 13 }}>Хэрэглэлийн төрөл</label>
                  <select style={inputStyle} value={recordForm.item} onChange={(e) => setRecordForm({ ...recordForm, item: e.target.value })} disabled={!canEditRecords}>
