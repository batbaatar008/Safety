          <div style={{ ...cardStyle, padding: 20 }}>
            <div style={{ display: "flex", gap: 8, alignItems: "center", color: "#475569", marginBottom: 8 }}><RefreshCw size={18} />Их олгогдсон төрөл</div>
            <div style={{ fontSize: 24, fontWeight: 800, color: "#0f172a" }}>{summary.topItem}</div>
