import streamlit as st
import pandas as pd
from datetime import datetime, timedelta
import os

# Хуудасны тохиргоо
st.set_page_config(page_title="Safety - Хувцасны бүртгэл", layout="wide")

# Өгөгдөл хадгалах файлын нэр
DATA_FILE = "uniform_data.csv"

# Хувцасны норм (Жилээр)
NORMS = {
    "Өвлийн ажлын хувцас": 2,
    "Өвлийн ажлын гутал": 2,
    "Зуны ажлын хувцас": 2,
    "Зуны ажлын гутал": 2,
    "Оффис цамц": 3,
    "Оффис хантааз": 3,
    "Хамгаалах дуулга": 5
}

# Анхны өгөгдлийг бэлдэх функц
def load_data():
    if os.path.exists(DATA_FILE):
        return pd.read_csv(DATA_FILE)
    else:
        # Хэрэв файл байхгүй бол хоосон бүтэц үүсгэнэ
        return pd.DataFrame(columns=[
            "Ажилтан", "Хүйс", "Хувцас", "Размер", "Олгосон огноо", "Дараагийн олголт", "Төлөв"
        ])

# Өгөгдөл хадгалах функц
def save_data(df):
    df.to_csv(DATA_FILE, index=False)

st.title("🛡️ Хэлтсийн ажлын хувцас хяналтын систем")

# Ажилчдын тогтмол мэдээлэл
STAFF_INFO = {
    "С.Батбаатар": {"албан_тушаал": "Хэлтсийн дарга", "хүйс": "Эр"},
    "Ч.Золзаяа": {"албан_тушаал": "Тооцооны инженер", "хүйс": "Эм"},
    "М.Ариунжаргал": {"албан_тушаал": "Эрчим хүч хэмнэлтийн менежер", "хүйс": "Эм"},
    "Б.Мөнхбат": {"албан_тушаал": "Гэрээний инженер", "хүйс": "Эр"},
    "Б.Энхтөр": {"албан_тушаал": "Тоолуур системийн ахлах инженер", "хүйс": "Эр"},
    "Ж.Баярсайхан": {"албан_тушаал": "Тоолуур системийн инженер", "хүйс": "Эр"},
    "Б.Төгөлдөр": {"албан_тушаал": "Судалгаа шинжилгээний инженер", "хүйс": "Эр"},
}

df = load_data()

# SIDEBAR - Бүртгэл оруулах хэсэг
with st.sidebar:
    st.header("➕ Шинэ бүртгэл")
    name = st.selectbox("Ажилтан", list(STAFF_INFO.keys()))
    gender = STAFF_INFO[name]["хүйс"]
    st.info(f"Хүйс: {gender}")
    
    item = st.selectbox("Хувцасны төрөл", list(NORMS.keys()))
    size = st.text_input("Размер (Жишээ нь: L, 42, XL)")
    date_gen = st.date_input("Олгосон огноо", datetime.now())
    
    if st.button("Хадгалах"):
        # Дараагийн олголтыг тооцох
        next_date = date_gen + timedelta(days=NORMS[item] * 365)
        
        new_row = {
            "Ажилтан": name,
            "Хүйс": gender,
            "Хувцас": item,
            "Размер": size,
            "Олгосон огноо": date_gen.strftime('%Y-%m-%d'),
            "Дараагийн олголт": next_date.strftime('%Y-%m-%d'),
            "Төлөв": "✅ Идэвхтэй"
        }
        
        # Хуучин өгөгдөл дээр нэмэх
        df = pd.concat([df, pd.DataFrame([new_row])], ignore_index=True)
        save_data(df)
        st.success("Амжилттай хадгалагдлаа!")

# ҮНДСЭН ХЭСЭГ - Хяналтын самбар
if not df.empty:
    # Огноог хөрвүүлэх
    df['Дараагийн олголт'] = pd.to_datetime(df['Дараагийн олголт'])
    
    # Төлөв шинэчлэх логик
    today = pd.Timestamp(datetime.now().date())
    def check_status(row):
        days_left = (row['Дараагийн олголт'] - today).days
        if days_left <= 0: return "❌ Хугацаа дууссан"
        if days_left <= 30: return "⚠️ Солих дөхсөн"
        return "✅ Идэвхтэй"

    df['Төлөв'] = df.apply(check_status, axis=1)

    # Шүүлтүүр
    st.subheader("📊 Нийт бүртгэл")
    col_f1, col_f2 = st.columns(2)
    with col_f1:
        search_name = st.multiselect("Ажилтнаар шүүх", options=df["Ажилтан"].unique())
    
    filtered_df = df
    if search_name:
        filtered_df = df[df["Ажилтан"].isin(search_name)]

    # Хүснэгтийн өнгө
    def style_row(val):
        color = 'white'
        if val == "❌ Хугацаа дууссан": color = '#ff4b4b'
        elif val == "⚠️ Солих дөхсөн": color = '#ffa500'
        return f'color: {color}; font-weight: bold'

    st.dataframe(filtered_df.style.applymap(style_row, subset=['Төлөв']), use_container_width=True)
    
    # Татаж авах (Excel-ээр ашиглах бол)
    csv = filtered_df.to_csv(index=False).encode('utf-8-sig')
    st.download_button("Excel рүү татах (.csv)", csv, "safety_report.csv", "text/csv")

else:
    st.warning("Одоогоор бүртгэл хоосон байна. Баруун талын цэснээс мэдээлэл оруулна уу.")
