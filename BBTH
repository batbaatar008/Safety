    employee: employees[0].name,
    position: employees[0].position,
    item: uniforms[0],
    size: "",
    qty: 1,
    issued_date: new Date().toISOString().slice(0, 10),
    note: "",
  });

  const [userForm, setUserForm] = useState({
    full_name: "",
    username: "",
    password: "",
    role: "viewer",
  });

  const canManageUsers = currentUser?.role === "admin";
  const canEditRecords = currentUser?.role === "admin" || currentUser?.role === "manager";

  useEffect(() => {
    bootstrap();
  }, []);

  async function bootstrap() {
    if (!supabase) {
      setUsers([DEFAULT_ADMIN]);
      setReady(true);
      return;
    }

    await ensureDefaultAdmin();
    await loadUsers();
    await loadRecords();
    setReady(true);
  }

  async function ensureDefaultAdmin() {
    const { data, error } = await supabase.from(TABLE_USERS).select("*").eq("username", DEFAULT_ADMIN.username).maybeSingle();
    if (error && !String(error.message).toLowerCase().includes("no rows")) {
      setStatus(`Хэрэглэгч шалгах үед алдаа: ${error.message}`);
      return;
    }
    if (!data) {
      const { error: insertError } = await supabase.from(TABLE_USERS).insert([DEFAULT_ADMIN]);
      if (insertError) setStatus(`Анхны админ үүсгэхэд алдаа: ${insertError.message}`);
    }
  }

  async function loadUsers() {
    if (!supabase) return;
    const { data, error } = await supabase.from(TABLE_USERS).select("*").order("created_at", { ascending: false });
    if (error) {
      setStatus(`Хэрэглэгчийн жагсаалт уншихад алдаа: ${error.message}`);
      return;
    }
    setUsers(data || []);
  }

  async function loadRecords() {
    if (!supabase) return;
    const { data, error } = await supabase.from(TABLE_RECORDS).select("*").order("issued_date", { ascending: false }).order("created_at", { ascending: false });
    if (error) {
      setStatus(`Бүртгэл уншихад алдаа: ${error.message}`);
      return;
    }
    setRecords(data || []);
  }

  async function handleLogin() {
    if (!login.username || !login.password) {
      alert("Нэвтрэх нэр, нууц үгээ оруулна уу.");
      return;
    }

    if (!supabase) {
      if (login.username === DEFAULT_ADMIN.username && login.password === DEFAULT_ADMIN.password) {
        setCurrentUser(DEFAULT_ADMIN);
        return;
      }
      alert("Supabase тохируулаагүй үед зөвхөн demo admin ашиглана.");
      return;
    }

    const { data, error } = await supabase
      .from(TABLE_USERS)
      .select("*")
      .eq("username", login.username)
      .eq("password", login.password)
      .eq("is_active", true)
      .maybeSingle();

    if (error) {
      alert(`Нэвтрэх үед алдаа: ${error.message}`);
      return;
    }
    if (!data) {
      alert("Нэвтрэх нэр эсвэл нууц үг буруу байна.");
      return;
    }

    setCurrentUser(data);
    setStatus(`${data.full_name} амжилттай нэвтэрлээ.`);
  }

  function logout() {
    setCurrentUser(null);
    setLogin({ username: "", password: "" });
  }

  async function addUser() {
    if (!canManageUsers) return;
    if (!userForm.full_name || !userForm.username || !userForm.password) {
      alert("Хэрэглэгчийн мэдээллээ бүрэн оруулна уу.");
      return;
    }

    if (!supabase) {
      alert("Supabase тохируулсны дараа хэрэглэгч хадгална.");
      return;
    }

    const payload = { ...userForm, is_active: true };
    const { error } = await supabase.from(TABLE_USERS).insert([payload]);
    if (error) {
      alert(`Хэрэглэгч нэмэхэд алдаа: ${error.message}`);
      return;
    }

    setUserForm({ full_name: "", username: "", password: "", role: "viewer" });
    await loadUsers();
    setStatus("Шинэ хэрэглэгч үүсгэлээ.");
  }

  async function toggleUserActive(target) {
    if (!canManageUsers) return;
    if (!supabase) {
      alert("Supabase тохируулсны дараа хэрэглэгчийн төлөв өөрчилнө.");
      return;
    }
    const { error } = await supabase.from(TABLE_USERS).update({ is_active: !target.is_active }).eq("id", target.id);
    if (error) {
      alert(`Төлөв өөрчлөхөд алдаа: ${error.message}`);
      return;
    }
    await loadUsers();
  }

  async function addRecord() {
    if (!canEditRecords) return;
    if (!recordForm.employee || !recordForm.item || !recordForm.issued_date) {
      alert("Бүртгэлийн мэдээллээ гүйцэд оруулна уу.");
      return;
    }
    if (!supabase) {
      alert("Supabase тохируулсны дараа онлайн хадгалалт ажиллана.");
      return;
    }

    const payload = {
      ...recordForm,
      qty: Number(recordForm.qty || 1),
      department: DEPARTMENT,
      created_by: currentUser?.username || "",
